# Intelink Web — Environment Variables
# Copy to .env.local for local dev, or set in docker-compose.yml for production.
#
# IMPORTANT: NEXT_PUBLIC_* vars are baked at Docker build time.
# Changing them requires a full image rebuild (docker compose build --no-cache).

# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-only, never expose to client

# ─── App URL (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://intelink.ia.br              # used for OAuth redirects

# ─── Neo4j (required for intelligence routes) ─────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ─── Telegram (optional — enables bot + login widget) ─────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here                  # from BotFather
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=IntelinkBOT           # BAKED AT BUILD TIME

# ─── OpenRouter (required for bot natural language routing) ───────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=alibaba/qwen-plus                      # optional, defaults to qwen-plus

# ─── Auth (required) ──────────────────────────────────────────────────────────
JWT_SECRET=a_long_random_string_for_signing_tokens      # min 32 chars

# ─── Optional integrations ────────────────────────────────────────────────────
# GUARD_BRASIL_API_KEY=...                              # PII audit (Guard Brasil)
# GUARD_BRASIL_URL=https://guard.egos.ia.br
