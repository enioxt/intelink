# EGOS Inteligência — Environment Configuration
# Copy this file to .env and fill in your values

# Domain Configuration
DOMAIN=inteligencia.egos.ia.br
NEXT_PUBLIC_APP_URL=https://inteligencia.egos.ia.br
NEXT_PUBLIC_API_URL=https://inteligencia.egos.ia.br/api

# Neo4j Database
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-strong-password-here
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
APP_ENV=production
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=https://inteligencia.egos.ia.br,http://localhost:3000

# Rate Limiting
RATE_LIMIT_ANON=60/minute
RATE_LIMIT_AUTH=300/minute

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 🤖 AI / LLM Configuration — Multi-Provider Setup
# =============================================================================
# O Intelink suporta múltiplos provedores de IA. Configure pelo menos um abaixo.
# 
# 💡 RECOMENDAÇÃO: Comece com OpenRouter (acesso a múltiplos modelos com uma key)
# ou DashScope (modelos Alibaba gratuitos e poderosos como Qwen)
# =============================================================================

# -----------------------------------------------------------------------------
# Opção 1: OpenRouter — RECOMENDADO para iniciantes
# 🌐 https://openrouter.ai
# • Uma API key = acesso a 100+ modelos (Gemini, Claude, GPT, Llama, etc.)
# • Modelos gratuitos disponíveis
# • Rate limits generosos para free tier
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# -----------------------------------------------------------------------------
# Opção 2: DashScope (Alibaba Cloud) — Melhor custo-benefício
# 🌐 https://dashscope.console.aliyun.com
# • Modelos Qwen superiores em português
# • 1 milhão de tokens GRÁTIS no cadastro
# • Preços muito competitivos
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_MODEL=qwen-plus

# -----------------------------------------------------------------------------
# Opção 3: Google AI Studio — API gratuita com cotas generosas
# 🌐 https://aistudio.google.com/app/apikey
# • Gemini 2.0 Flash: 1,500 requests/dia GRÁTIS
# • Não precisa de cartão de crédito
# • Ótimo para desenvolvimento
# -----------------------------------------------------------------------------
GOOGLE_AI_API_KEY=AIza...
GOOGLE_AI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Opção 4: Anthropic Claude — Qualidade premium
# 🌐 https://console.anthropic.com
# • Claude 3.5 Sonnet: excelente para análise jurídica
# • Claude 3 Haiku: rápido e econômico
# • API paga, mas com qualidade superior
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Opção 5: OpenAI — GPT-4, GPT-3.5
# 🌐 https://platform.openai.com
# • GPT-4o: modelo mais capaz
# • GPT-3.5 Turbo: econômico para tarefas simples
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# 🎯 PRIORITY ORDER — Ordem de fallback (se múltiplas keys configuradas)
# O sistema tentará na ordem: DASHSCOPE → OPENROUTER → GOOGLE → ANTHROPIC → OPENAI
# Ajuste conforme suas preferências de custo/qualidade
# -----------------------------------------------------------------------------
AI_PROVIDER_PRIORITY=dashscope,openrouter,google,anthropic,openai

# Modelo padrão para tarefas gerais (usado se nenhum específico definido)
AI_MODEL=google/gemini-2.0-flash-001

# External APIs (optional)
PORTAL_TRANSPARENCIA_API_KEY=
DATAJUD_API_KEY=
BRAVE_API_KEY=

# Frontend
NEXT_PUBLIC_APP_NAME=EGOS Inteligência
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_INTELINK_API=http://localhost:8000/api/v1

# WhatsApp (Evolution API) - optional
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Telegram Bot (Feedback notifications)
# ⚠️ NEVER commit real tokens - use bot Father to generate: https://t.me/botfather
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
NEXT_PUBLIC_TELEGRAM_ADMIN_CHAT_ID=your-telegram-user-id

# Supabase (optional, for extended features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
