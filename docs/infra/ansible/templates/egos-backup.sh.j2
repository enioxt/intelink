#!/bin/bash
# EGOS Backup Script
# Backup automatizado de dados críticos

set -euo pipefail

APP_DIR="{{ app_dir }}"
BACKUP_DIR="$APP_DIR/backups"
DATE=$(date +%Y%m%d_%H%M%S)
RETENTION_DAYS={{ backup_retention_days | default(7) }}
S3_BUCKET="{{ s3_backup_bucket | default('') }}"
ALERT_EMAIL="{{ alert_email | default('') }}"

LOG_FILE="$APP_DIR/logs/backup.log"

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() {
    echo "[$(date -Iseconds)] $1" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}❌ $1${NC}" | tee -a "$LOG_FILE"
    if [ -n "$ALERT_EMAIL" ]; then
        echo "Backup failed: $1" | mail -s "EGOS Backup Alert" "$ALERT_EMAIL" 2>/dev/null || true
    fi
}

success() {
    echo -e "${GREEN}✅ $1${NC}" | tee -a "$LOG_FILE"
}

warn() {
    echo -e "${YELLOW}⚠️  $1${NC}" | tee -a "$LOG_FILE"
}

# Criar diretório de backup
mkdir -p "$BACKUP_DIR"

log "Starting backup: $DATE"

# ==========================================
# 1. Backup Neo4j
# ==========================================
backup_neo4j() {
    log "Backing up Neo4j..."
    
    local neo4j_container=$(docker ps -q -f name=neo4j)
    
    if [ -z "$neo4j_container" ]; then
        warn "Neo4j container not running, skipping..."
        return 0
    fi
    
    local backup_file="neo4j_$DATE.dump"
    
    if docker exec "$neo4j_container" neo4j-admin database dump neo4j --to-path="/backups/$backup_file" 2>/dev/null; then
        success "Neo4j backup: $backup_file"
        
        # Comprimir
        gzip -f "$BACKUP_DIR/$backup_file" 2>/dev/null || true
        return 0
    else
        error "Neo4j backup failed"
        return 1
    fi
}

# ==========================================
# 2. Backup Redis
# ==========================================
backup_redis() {
    log "Backing up Redis..."
    
    local redis_container=$(docker ps -q -f name=redis)
    
    if [ -z "$redis_container" ]; then
        warn "Redis container not running, skipping..."
        return 0
    fi
    
    # Trigger BGSAVE
    if docker exec "$redis_container" redis-cli BGSAVE 2>/dev/null; then
        # Aguardar salvamento
        sleep 2
        
        # Copiar dump.rdb
        local backup_file="redis_$DATE.rdb"
        if docker cp "$redis_container:/data/dump.rdb" "$BACKUP_DIR/$backup_file"; then
            success "Redis backup: $backup_file"
            gzip -f "$BACKUP_DIR/$backup_file" 2>/dev/null || true
            return 0
        fi
    fi
    
    warn "Redis backup skipped (non-persistent or error)"
    return 0
}

# ==========================================
# 3. Backup Caddy (certificates)
# ==========================================
backup_caddy() {
    log "Backing up Caddy certificates..."
    
    local caddy_data="$APP_DIR/data/caddy"
    local backup_file="caddy_$DATE.tar.gz"
    
    if [ -d "$caddy_data" ]; then
        if tar -czf "$BACKUP_DIR/$backup_file" -C "$caddy_data" . 2>/dev/null; then
            success "Caddy backup: $backup_file"
            return 0
        else
            warn "Caddy backup failed (may be in use)"
        fi
    fi
    
    return 0
}

# ==========================================
# 4. Backup .env e configurações
# ==========================================
backup_config() {
    log "Backing up configuration..."
    
    local backup_file="config_$DATE.tar.gz"
    
    if [ -f "$APP_DIR/.env" ]; then
        if tar -czf "$BACKUP_DIR/$backup_file" -C "$APP_DIR" .env docker-compose.yml Caddyfile 2>/dev/null; then
            success "Config backup: $backup_file"
            return 0
        fi
    fi
    
    warn "Config backup skipped (no .env found)"
    return 0
}

# ==========================================
# 5. Cleanup antigos
# ==========================================
cleanup_old() {
    log "Cleaning up old backups (>$RETENTION_DAYS days)..."
    
    local deleted=$(find "$BACKUP_DIR" -name "*.dump*" -o -name "*.rdb*" -o -name "*.tar.gz" -mtime +$RETENTION_DAYS -delete -print | wc -l)
    
    if [ "$deleted" -gt 0 ]; then
        log "Deleted $deleted old backup files"
    fi
}

# ==========================================
# 6. Upload S3 (opcional)
# ==========================================
upload_s3() {
    if [ -z "$S3_BUCKET" ]; then
        return 0
    fi
    
    log "Uploading to S3..."
    
    if command -v aws &> /dev/null; then
        aws s3 sync "$BACKUP_DIR" "s3://$S3_BUCKET/backups/" --storage-class STANDARD_IA
        success "S3 upload complete"
    else
        warn "AWS CLI not installed, skipping S3 upload"
    fi
}

# ==========================================
# Main
# ==========================================
main() {
    local failed=0
    
    echo "========================================"
    echo "📦 EGOS Backup"
    echo "Date: $(date)"
    echo "========================================"
    echo ""
    
    backup_neo4j || ((failed++))
    backup_redis || ((failed++))
    backup_caddy || true
    backup_config || true
    
    echo ""
    cleanup_old
    upload_s3
    
    echo ""
    echo "========================================"
    
    if [ $failed -eq 0 ]; then
        success "Backup completed: $DATE"
        exit 0
    else
        error "Backup completed with $failed failures"
        exit 1
    fi
}

main "$@"
