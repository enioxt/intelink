#!/bin/bash
# EGOS Deploy Script
# Deploy automatizado da aplicação

set -euo pipefail

APP_DIR="{{ app_dir }}"
REPO_URL="https://github.com/enioxt/intelink.git"
BRANCH="${1:-main}"

LOG_FILE="$APP_DIR/logs/deploy.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() {
    echo "[$(date -Iseconds)] $1" | tee -a "$LOG_FILE"
}

step() {
    echo -e "${BLUE}▶ $1${NC}" | tee -a "$LOG_FILE"
}

success() {
    echo -e "${GREEN}✅ $1${NC}" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}❌ $1${NC}" | tee -a "$LOG_FILE"
}

warn() {
    echo -e "${YELLOW}⚠️  $1${NC}" | tee -a "$LOG_FILE"
}

# ==========================================
# Pre-deploy checks
# ==========================================
check_prerequisites() {
    step "Checking prerequisites..."
    
    if ! command -v docker &> /dev/null; then
        error "Docker not installed"
        exit 1
    fi
    
    if ! command -v git &> /dev/null; then
        error "Git not installed"
        exit 1
    fi
    
    success "Prerequisites OK"
}

# ==========================================
# Clone or pull
# ==========================================
update_code() {
    step "Updating code..."
    
    if [ -d "$APP_DIR/.git" ]; then
        cd "$APP_DIR"
        git fetch origin
        git checkout "$BRANCH"
        git pull origin "$BRANCH"
    else
        git clone "$REPO_URL" "$APP_DIR"
        cd "$APP_DIR"
        git checkout "$BRANCH"
    fi
    
    success "Code updated to branch: $BRANCH"
}

# ==========================================
# Check .env
# ==========================================
check_env() {
    step "Checking environment..."
    
    if [ ! -f "$APP_DIR/.env" ]; then
        if [ -f "$APP_DIR/.env.example" ]; then
            warn ".env not found, copying from .env.example"
            cp "$APP_DIR/.env.example" "$APP_DIR/.env"
            warn "⚠️  IMPORTANT: Edit $APP_DIR/.env with real values!"
        else
            error ".env file not found"
            exit 1
        fi
    fi
    
    success "Environment OK"
}

# ==========================================
# Build and deploy
# ==========================================
deploy() {
    step "Building and deploying..."
    
    cd "$APP_DIR"
    
    # Pull latest images
    docker compose pull
    
    # Build
    docker compose build --no-cache
    
    # Deploy
    docker compose up -d
    
    # Wait for services
    sleep 10
    
    # Health check
    if curl -sf http://localhost:8000/health > /dev/null 2>&1; then
        success "API is healthy"
    else
        warn "API health check failed (may still be starting)"
    fi
    
    if curl -sf http://localhost:3000 > /dev/null 2>&1; then
        success "Frontend is responding"
    else
        warn "Frontend not responding (may still be building)"
    fi
    
    success "Deploy completed"
}

# ==========================================
# Cleanup
# ==========================================
cleanup() {
    step "Cleaning up..."
    
    # Remove old images
    docker image prune -f
    
    # Remove unused volumes
    docker volume prune -f
    
    success "Cleanup completed"
}

# ==========================================
# Main
# ==========================================
main() {
    echo "========================================"
    echo "🚀 EGOS Deploy"
    echo "Branch: $BRANCH"
    echo "Time: $(date)"
    echo "========================================"
    echo ""
    
    check_prerequisites
    update_code
    check_env
    deploy
    cleanup
    
    echo ""
    echo "========================================"
    success "Deploy finished successfully!"
    echo "URL: https://intelink.ia.br"
    echo ""
    echo "Useful commands:"
    echo "  docker compose logs -f api"
    echo "  docker compose logs -f frontend"
    echo "  docker compose ps"
}

main "$@"
