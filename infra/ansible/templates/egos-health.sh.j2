#!/bin/bash
# EGOS Health Check Script
# Verifica saúde dos serviços

set -euo pipefail

API_URL="http://localhost:8000/health"
FRONTEND_URL="http://localhost:3000"
NEO4J_URL="bolt://localhost:7687"
REDIS_URL="redis://localhost:6379"

LOG_FILE="{{ app_dir }}/logs/health-check.log"
ALERT_EMAIL="{{ alert_email | default('') }}"

# Colors for terminal output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log() {
    echo "[$(date -Iseconds)] $1" | tee -a "$LOG_FILE"
}

alert() {
    local message="$1"
    log "ALERT: $message"
    if [ -n "$ALERT_EMAIL" ]; then
        echo "$message" | mail -s "EGOS Health Alert" "$ALERT_EMAIL" 2>/dev/null || true
    fi
}

check_api() {
    if curl -sf "$API_URL" > /dev/null 2>&1; then
        echo -e "${GREEN}✅${NC} API (port 8000)"
        log "API: OK"
        return 0
    else
        echo -e "${RED}❌${NC} API (port 8000)"
        log "API: FAIL"
        alert "API health check failed"
        return 1
    fi
}

check_frontend() {
    if curl -sf "$FRONTEND_URL" > /dev/null 2>&1; then
        echo -e "${GREEN}✅${NC} Frontend (port 3000)"
        log "Frontend: OK"
        return 0
    else
        echo -e "${YELLOW}⚠️${NC} Frontend (port 3000)"
        log "Frontend: FAIL (may be building)"
        return 0  # Don't fail on frontend during build
    fi
}

check_docker() {
    if docker ps > /dev/null 2>&1; then
        local running=$(docker ps -q | wc -l)
        echo -e "${GREEN}✅${NC} Docker ($running containers running)"
        log "Docker: $running containers"
        return 0
    else
        echo -e "${RED}❌${NC} Docker"
        log "Docker: FAIL"
        alert "Docker daemon not responding"
        return 1
    fi
}

check_disk() {
    local usage=$(df -h / | awk 'NR==2 {print $5}' | tr -d '%')
    if [ "$usage" -lt 80 ]; then
        echo -e "${GREEN}✅${NC} Disk usage (${usage}%)"
        log "Disk: ${usage}%"
        return 0
    elif [ "$usage" -lt 90 ]; then
        echo -e "${YELLOW}⚠️${NC} Disk usage (${usage}%)"
        log "Disk: WARNING ${usage}%"
        return 0
    else
        echo -e "${RED}❌${NC} Disk usage (${usage}%)"
        log "Disk: CRITICAL ${usage}%"
        alert "Disk usage critical: ${usage}%"
        return 1
    fi
}

check_memory() {
    local usage=$(free | awk 'NR==2{printf "%.0f", $3*100/$2}')
    if [ "$usage" -lt 80 ]; then
        echo -e "${GREEN}✅${NC} Memory usage (${usage}%)"
        log "Memory: ${usage}%"
        return 0
    else
        echo -e "${YELLOW}⚠️${NC} Memory usage (${usage}%)"
        log "Memory: WARNING ${usage}%"
        return 0
    fi
}

check_load() {
    local load=$(uptime | awk -F'load average:' '{print $2}' | awk '{print $1}' | tr -d ',')
    local cores=$(nproc)
    local percentage=$(awk "BEGIN {printf \"%.0f\", ($load/$cores)*100}")
    
    if [ "$percentage" -lt 80 ]; then
        echo -e "${GREEN}✅${NC} Load average (${load})"
        log "Load: ${load}"
        return 0
    else
        echo -e "${YELLOW}⚠️${NC} Load average (${load})"
        log "Load: HIGH ${load}"
        return 0
    fi
}

# Main
main() {
    echo "========================================"
    echo "🔍 EGOS Health Check"
    echo "Time: $(date)"
    echo "========================================"
    echo ""
    
    local failed=0
    
    check_docker || ((failed++))
    echo ""
    
    check_api || ((failed++))
    check_frontend || ((failed++))
    echo ""
    
    check_disk || ((failed++))
    check_memory || ((failed++))
    check_load || ((failed++))
    
    echo ""
    echo "========================================"
    
    if [ $failed -eq 0 ]; then
        echo -e "${GREEN}🎉 All systems operational${NC}"
        exit 0
    else
        echo -e "${YELLOW}⚠️  $failed check(s) failed${NC}"
        exit 1
    fi
}

main "$@"
